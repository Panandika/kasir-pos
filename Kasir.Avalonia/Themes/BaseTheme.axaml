<!-- Specificity smoke test: DataGrid Background override verified by App.axaml include order (BaseTheme last wins). -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <Styles.Resources>
    <ResourceDictionary>

      <!-- ============================================================ -->
      <!-- COLOR TOKENS — 17 semantic tokens (DESIGN-SYSTEM.md §5.1)   -->
      <!-- Each token emitted as Color + SolidColorBrush                -->
      <!-- ============================================================ -->

      <!-- Background surfaces -->
      <Color x:Key="Bg0Color">#FF000000</Color>
      <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0Color}"/>

      <Color x:Key="Bg1Color">#FF001400</Color>
      <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1Color}"/>

      <Color x:Key="Bg2Color">#FF002800</Color>
      <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2Color}"/>

      <Color x:Key="BgHoverColor">#FF003800</Color>
      <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHoverColor}"/>

      <Color x:Key="BgSelectedColor">#FF004400</Color>
      <SolidColorBrush x:Key="BgSelectedBrush" Color="{StaticResource BgSelectedColor}"/>

      <!-- AccentBg: dark amber/danger background for destructive actions -->
      <Color x:Key="AccentBgColor">#FF440000</Color>
      <SolidColorBrush x:Key="AccentBgBrush" Color="{StaticResource AccentBgColor}"/>

      <!-- Border tokens -->
      <Color x:Key="BorderSubtleColor">#FF00A000</Color>
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>

      <Color x:Key="BorderStrongColor">#FF006400</Color>
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>

      <!-- Foreground tokens -->
      <Color x:Key="FgPrimaryColor">#FF00DC00</Color>
      <SolidColorBrush x:Key="FgPrimaryBrush" Color="{StaticResource FgPrimaryColor}"/>

      <Color x:Key="FgNumericColor">#FFFFC800</Color>
      <SolidColorBrush x:Key="FgNumericBrush" Color="{StaticResource FgNumericColor}"/>

      <Color x:Key="FgSecondaryColor">#FF008800</Color>
      <SolidColorBrush x:Key="FgSecondaryBrush" Color="{StaticResource FgSecondaryColor}"/>

      <Color x:Key="FgDimColor">#FF006400</Color>
      <SolidColorBrush x:Key="FgDimBrush" Color="{StaticResource FgDimColor}"/>

      <!-- Semantic state tokens -->
      <Color x:Key="AccentColor">#FFFFC800</Color>
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

      <Color x:Key="SuccessColor">#FF00DC00</Color>
      <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

      <Color x:Key="WarningColor">#FFFF9900</Color>
      <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>

      <Color x:Key="DangerColor">#FFFF5050</Color>
      <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

      <Color x:Key="FocusRingColor">#FF00DC00</Color>
      <SolidColorBrush x:Key="FocusRingBrush" Color="{StaticResource FocusRingColor}"/>

      <!-- ============================================================ -->
      <!-- FONT FAMILY RESOURCES                                         -->
      <!-- Using system-available fallbacks (font embedding = follow-up) -->
      <!-- ============================================================ -->
      <FontFamily x:Key="PlexSansFont">Segoe UI,Inter,sans-serif</FontFamily>
      <FontFamily x:Key="JetBrainsMonoFont">Consolas,JetBrains Mono,Cascadia Mono,monospace</FontFamily>
      <FontFamily x:Key="PlexMonoFont">Consolas,JetBrains Mono,Cascadia Mono,monospace</FontFamily>

      <!-- ============================================================ -->
      <!-- DENSITY TOKENS — Compact defaults (DESIGN-SYSTEM.md §4)      -->
      <!-- ============================================================ -->
      <system:Double x:Key="RowHeight">22</system:Double>
      <system:Double x:Key="ControlHeight">24</system:Double>
      <system:Double x:Key="FontSizeBody">12</system:Double>
      <system:Double x:Key="FontSizeLabel">11</system:Double>
      <system:Double x:Key="FontSizeNumeric">13</system:Double>
      <system:Double x:Key="FontSizeHeading">14</system:Double>
      <system:Double x:Key="CellPaddingX">6</system:Double>
      <system:Double x:Key="CellPaddingY">4</system:Double>
      <system:Double x:Key="SectionGap">8</system:Double>
      <system:Double x:Key="FormPadding">8</system:Double>
      <system:Double x:Key="BorderWidth">1</system:Double>
      <system:Double x:Key="FocusRingWidth">2</system:Double>

    </ResourceDictionary>
  </Styles.Resources>

  <!-- ============================================================ -->
  <!-- SHARED STYLES — Baseline overrides over FluentTheme defaults  -->
  <!-- DS-3 batches will fine-tune per-form needs                   -->
  <!-- ============================================================ -->

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource Bg1Brush}"/>
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
    <Setter Property="Height" Value="{DynamicResource ControlHeight}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource Bg2Brush}"/>
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
    <Setter Property="Height" Value="{DynamicResource ControlHeight}"/>
  </Style>

  <Style Selector="Menu">
    <Setter Property="Background" Value="{DynamicResource Bg0Brush}"/>
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
  </Style>

  <!-- ============================================================ -->
  <!-- DATAGRID — Terminal-style density overrides                   -->
  <!-- Specificity: BaseTheme included AFTER FluentTheme in App.axaml -->
  <!-- ============================================================ -->

  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource Bg0Brush}"/>
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderSubtleBrush}"/>
    <Setter Property="RowHeight" Value="22"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style Selector="DataGridRow">
    <Setter Property="Background" Value="{DynamicResource Bg0Brush}"/>
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
  </Style>

  <!-- Selected row: dark green background, bright green text -->
  <Style Selector="DataGridRow:selected /template/ Border#BackgroundBorder">
    <Setter Property="Background" Value="{DynamicResource BgSelectedBrush}"/>
  </Style>

  <!-- Hover row: slightly lighter dark green -->
  <Style Selector="DataGridRow:pointerover /template/ Border#BackgroundBorder">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
  </Style>

  <!-- Selected+hover: keep selected color (selected wins) -->
  <Style Selector="DataGridRow:pointerover:selected /template/ Border#BackgroundBorder">
    <Setter Property="Background" Value="{DynamicResource BgSelectedBrush}"/>
  </Style>

  <!-- Cell: minimal terminal-style padding -->
  <Style Selector="DataGridCell">
    <Setter Property="Padding" Value="6,2"/>
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- Selected cell: inherit row selection color, no extra border -->
  <Style Selector="DataGridCell:selected">
    <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
  </Style>

  <!-- Column header: dark green background, dim green text -->
  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource Bg1Brush}"/>
    <Setter Property="Foreground" Value="{DynamicResource FgSecondaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource PlexMonoFont}"/>
    <Setter Property="FontSize" Value="{DynamicResource FontSizeLabel}"/>
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
  </Style>

  <!-- Column header hover -->
  <Style Selector="DataGridColumnHeader:pointerover">
    <Setter Property="Background" Value="{DynamicResource Bg2Brush}"/>
  </Style>

  <!-- ============================================================ -->
  <!-- DATAGRID SCROLLBAR — Thin, dark, terminal-matching           -->
  <!-- ============================================================ -->

  <!-- Vertical scrollbar track -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:vertical">
    <Setter Property="Background" Value="{DynamicResource Bg1Brush}"/>
    <Setter Property="Width" Value="10"/>
  </Style>

  <!-- Vertical scrollbar thumb -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:vertical /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}"/>
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <!-- Vertical scrollbar thumb hover -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:vertical /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource FgSecondaryBrush}"/>
  </Style>

  <!-- Horizontal scrollbar track -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:horizontal">
    <Setter Property="Background" Value="{DynamicResource Bg1Brush}"/>
    <Setter Property="Height" Value="10"/>
  </Style>

  <!-- Horizontal scrollbar thumb -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:horizontal /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}"/>
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <!-- Horizontal scrollbar thumb hover -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar:horizontal /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource FgSecondaryBrush}"/>
  </Style>

  <!-- Scrollbar repeat buttons (line up/down/left/right) — hide for minimal look -->
  <Style Selector="DataGrid /template/ ScrollViewer /template/ ScrollBar Button">
    <Setter Property="Width" Value="0"/>
    <Setter Property="Height" Value="0"/>
  </Style>

</Styles>
