<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.MainWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000"
        Title="Kasir">
  <DockPanel>
    <Border DockPanel.Dock="Bottom"
            Background="#002800"
            BorderBrush="#00a000"
            BorderThickness="0,1,0,0"
            Padding="8,3">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="StatusLabel"
                   Grid.Column="0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="12"
                   Foreground="#00dc00"
                   VerticalAlignment="Center"
                   Text="Kasir POS — ready" />
        <TextBlock x:Name="ClockLabel"
                   Grid.Column="1"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="12"
                   Foreground="#00a000"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>
    <TextBlock Text="Kasir POS"
               FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
               FontSize="24"
               Foreground="#00dc00"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
  </DockPanel>
</Window>
