<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Reports.SupplierReportWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="LblSummary"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="0,0,12,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="#002800" Height="44" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Cari:"
                   Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtSearch"
                 Width="300"
                 Height="28"
                 Background="#001400"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
      </StackPanel>
    </Border>
    <DataGrid x:Name="DgvReport"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="#001400"
              Foreground="#00dc00"
              GridLinesVisibility="Horizontal"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"           Binding="{Binding Code}"    Width="1.5*" />
        <DataGridTextColumn Header="Nama"           Binding="{Binding Name}"    Width="3*"   />
        <DataGridTextColumn Header="Alamat"         Binding="{Binding Address}" Width="4*"   />
        <DataGridTextColumn Header="Telepon"        Binding="{Binding Phone}"   Width="1.5*" />
        <DataGridTextColumn Header="Contact Person" Binding="{Binding Contact}" Width="2*"   />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
