<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Reports.ProductReportView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="LblSummary"
                 Foreground="{DynamicResource FgNumericBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="0,0,12,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg2Brush}" Height="44" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Cari:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource PlexSansFont}"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtSearch"
                 Width="300"
                 Height="28"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" />
      </StackPanel>
    </Border>
    <DataGrid x:Name="DgvReport"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="{DynamicResource Bg1Brush}"
              Foreground="{DynamicResource FgPrimaryBrush}"
              GridLinesVisibility="Horizontal"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"       Binding="{Binding Code}"    Width="1.5*" />
        <DataGridTextColumn Header="Barcode"    Binding="{Binding Barcode}" Width="1.5*" />
        <DataGridTextColumn Header="Nama"       Binding="{Binding Name}"    Width="3*"   />
        <DataGridTextColumn Header="Satuan"     Binding="{Binding Unit}"    Width="0.8*" />
        <DataGridTextColumn Header="Dept"       Binding="{Binding Dept}"    Width="0.8*" />
        <DataGridTextColumn Header="Harga Jual" Binding="{Binding Price}"   Width="1.2*" />
        <DataGridTextColumn Header="Harga Beli" Binding="{Binding Buying}"  Width="1.2*" />
        <DataGridTextColumn Header="HPP"        Binding="{Binding Cost}"    Width="1.2*" />
        <DataGridTextColumn Header="Status"     Binding="{Binding Status}"  Width="0.6*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
