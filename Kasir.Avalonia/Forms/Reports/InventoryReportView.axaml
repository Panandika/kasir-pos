<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Reports.InventoryReportView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="LblSummary"
                 Foreground="{DynamicResource FgNumericBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="0,0,12,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg2Brush}" Height="44" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <ComboBox x:Name="CboReportType"
                  Width="220"
                  Height="28"
                  Background="{DynamicResource Bg1Brush}"
                  Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource PlexSansFont}"
                  FontSize="13" />
        <TextBlock Text="From:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource PlexSansFont}"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtDateFrom"
                 Width="110"
                 Height="28"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" />
        <TextBlock Text="To:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource PlexSansFont}"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtDateTo"
                 Width="110"
                 Height="28"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" />
        <Button x:Name="BtnGenerate"
                Content="F5"
                Width="50"
                Height="28"
                Background="{DynamicResource AccentBgBrush}"
                Foreground="{DynamicResource FgPrimaryBrush}"
                FontFamily="{DynamicResource PlexSansFont}"
                FontSize="13" />
        <Button x:Name="BtnExport"
                Content="F7"
                Width="50"
                Height="28"
                Background="{DynamicResource AccentBgBrush}"
                Foreground="{DynamicResource FgPrimaryBrush}"
                FontFamily="{DynamicResource PlexSansFont}"
                FontSize="13" />
      </StackPanel>
    </Border>
    <DataGrid x:Name="DgvReport"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="{DynamicResource Bg1Brush}"
              Foreground="{DynamicResource FgPrimaryBrush}"
              GridLinesVisibility="Horizontal"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13">
      <DataGrid.Columns>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
