<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Reports.SupplierReportView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="LblSummary"
                 Foreground="{DynamicResource FgNumericBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="0,0,12,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg2Brush}" Height="44" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Cari:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource PlexSansFont}"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtSearch"
                 Width="300"
                 Height="28"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" />
      </StackPanel>
    </Border>
    <DataGrid x:Name="DgvReport"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="{DynamicResource Bg1Brush}"
              Foreground="{DynamicResource FgPrimaryBrush}"
              GridLinesVisibility="Horizontal"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"           Binding="{Binding Code}"    Width="1.5*" />
        <DataGridTextColumn Header="Nama"           Binding="{Binding Name}"    Width="3*"   />
        <DataGridTextColumn Header="Alamat"         Binding="{Binding Address}" Width="4*"   />
        <DataGridTextColumn Header="Telepon"        Binding="{Binding Phone}"   Width="1.5*" />
        <DataGridTextColumn Header="Contact Person" Binding="{Binding Contact}" Width="2*"   />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
