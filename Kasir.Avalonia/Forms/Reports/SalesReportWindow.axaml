<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Reports.SalesReportWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="LblSummary"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="0,0,12,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="#002800" Height="44" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="From:"
                   Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtDateFrom"
                 Width="120"
                 Height="28"
                 Background="#001400"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <TextBlock Text="To:"
                   Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13"
                   VerticalAlignment="Center" />
        <TextBox x:Name="TxtDateTo"
                 Width="120"
                 Height="28"
                 Background="#001400"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <Button x:Name="BtnGenerate"
                Content="F5"
                Width="50"
                Height="28"
                Background="#004400"
                Foreground="#00dc00"
                FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                FontSize="13" />
        <Button x:Name="BtnExport"
                Content="F7"
                Width="50"
                Height="28"
                Background="#004400"
                Foreground="#00dc00"
                FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                FontSize="13" />
      </StackPanel>
    </Border>
    <DataGrid x:Name="DgvReport"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="#001400"
              Foreground="#00dc00"
              GridLinesVisibility="Horizontal"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="No"       Binding="{Binding No}"        Width="0.4*" />
        <DataGridTextColumn Header="No.Nota"  Binding="{Binding JournalNo}" Width="2*"   />
        <DataGridTextColumn Header="Tanggal"  Binding="{Binding Date}"      Width="1.5*" />
        <DataGridTextColumn Header="Kasir"    Binding="{Binding Cashier}"   Width="1*"   />
        <DataGridTextColumn Header="Items"    Binding="{Binding Items}"     Width="0.6*" />
        <DataGridTextColumn Header="Bruto"    Binding="{Binding Gross}"     Width="1.2*" />
        <DataGridTextColumn Header="Diskon"   Binding="{Binding Disc}"      Width="1*"   />
        <DataGridTextColumn Header="Total"    Binding="{Binding Total}"     Width="1.2*" />
        <DataGridTextColumn Header="Tunai"    Binding="{Binding Cash}"      Width="1.2*" />
        <DataGridTextColumn Header="Kartu"    Binding="{Binding Card}"      Width="1*"   />
        <DataGridTextColumn Header="Status"   Binding="{Binding Status}"    Width="0.8*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
