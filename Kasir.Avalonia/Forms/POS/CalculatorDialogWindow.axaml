<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.POS.CalculatorDialogWindow"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#000000"
        WindowDecorations="None">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button x:Name="BtnOk" Content="OK"
              Width="90" Height="32"
              Background="#004400" Foreground="#00dc00"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13" />
      <Button x:Name="BtnTutup" Content="Tutup"
              Width="90" Height="32"
              Background="#440000" Foreground="#ff5050"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13" />
    </StackPanel>
    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*" Margin="0,8,0,0">
      <!-- Row 0: multiply -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12"
                  VerticalAlignment="Center">
        <TextBox x:Name="TxtA" Width="100" Height="30"
                 TextAlignment="Right"
                 Background="#001400" Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <TextBlock Text="×" Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center" />
        <TextBox x:Name="TxtB" Width="100" Height="30"
                 TextAlignment="Right"
                 Background="#001400" Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <TextBlock Text="=" Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center" />
        <TextBlock x:Name="LblMultResult" Text="0"
                   Foreground="#ffc800" Width="100"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center"
                   TextAlignment="Right" />
      </StackPanel>
      <!-- Row 1: add -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                  VerticalAlignment="Center">
        <TextBox x:Name="TxtC" Width="100" Height="30"
                 TextAlignment="Right"
                 Background="#001400" Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <TextBlock Text="+" Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center" />
        <TextBox x:Name="TxtD" Width="100" Height="30"
                 TextAlignment="Right"
                 Background="#001400" Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <TextBlock Text="=" Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center" />
        <TextBlock x:Name="LblAddResult" Text="0"
                   Foreground="#ffc800" Width="100"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" VerticalAlignment="Center"
                   TextAlignment="Right" />
      </StackPanel>
    </Grid>
  </DockPanel>
</Window>
