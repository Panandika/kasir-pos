<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Master.PriceChangeWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Border>

    <!-- Header: search -->
    <Border DockPanel.Dock="Top" Background="#001400" Height="40"
            BorderBrush="#00a000" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
        <TextBlock Text="Cari:"
                   Foreground="#006400"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" />
        <TextBox x:Name="TxtSearch"
                 Width="300"
                 Background="#001400" Foreground="#00dc00" CaretBrush="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" Height="28" />
        <TextBlock Text="  F5: Muat  Enter: Edit Harga  F10: Simpan  Esc: Keluar"
                   Foreground="#006400"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="12" />
      </StackPanel>
    </Border>

    <!-- Products grid (read-only list; price editing via dialog) -->
    <DataGrid x:Name="DgvPrices"
              AutoGenerateColumns="False"
              SelectionMode="Single"
              Foreground="#00dc00"
              Background="#001400"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              IsReadOnly="True"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"       Binding="{Binding Code}"     Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Nama Barang" Binding="{Binding Name}"    Width="3*"   CanUserSort="False" />
        <DataGridTextColumn Header="Jual Lama"  Binding="{Binding OldPrice}" Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Jual Baru"  Binding="{Binding NewPrice}" Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Beli"       Binding="{Binding BuyPrice}" Width="1.2*" CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
