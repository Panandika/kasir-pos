<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Kasir.Avalonia.Converters"
        x:Class="Kasir.Avalonia.Forms.Master.ProductView"
        x:DataType="x:Object"
        Background="{DynamicResource Bg0Brush}">
  <UserControl.Resources>
    <conv:StockColorConverter x:Key="StockColorConverter"/>
  </UserControl.Resources>
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel" Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
    </Panel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg2Brush}" Height="38" Padding="8,4">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="Search:" Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBox Grid.Column="1" x:Name="TxtSearch" Height="28" Margin="0,0,8,0"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}" FontSize="13"/>
        <Button Grid.Column="2" x:Name="BtnSearch" Content="F2" Width="50" Height="28"
                Background="{DynamicResource BgSelectedBrush}"
                Foreground="{DynamicResource FgPrimaryBrush}"
                FontFamily="{DynamicResource JetBrainsMonoFont}" FontSize="13"/>
      </Grid>
    </Border>
    <Grid RowDefinitions="3*,2*">
      <DataGrid Grid.Row="0" x:Name="DgvProducts" AutoGenerateColumns="False" IsReadOnly="True"
                Background="{DynamicResource Bg1Brush}"
                Foreground="{DynamicResource FgPrimaryBrush}"
                GridLinesVisibility="Horizontal"
                FontFamily="{DynamicResource JetBrainsMonoFont}"
                FontSize="13"
                HorizontalAlignment="Stretch"
                x:CompileBindings="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Kode"        Binding="{Binding Code}"         Width="1.2*" CanUserSort="False"/>
          <DataGridTextColumn Header="Nama Barang" Binding="{Binding Name}"         Width="3.5*" CanUserSort="False"/>
          <DataGridTextColumn Header="Barcode"     Binding="{Binding Barcode}"      Width="1.8*" CanUserSort="False"/>
          <DataGridTextColumn Header="Harga"       Binding="{Binding Price}"        Width="1.3*" CanUserSort="False"/>
          <DataGridTemplateColumn Header="Stok Toko" Width="1.0*" CanUserSort="False">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding StockStore}" Foreground="{Binding StockStore, Converter={StaticResource StockColorConverter}}" FontFamily="{DynamicResource JetBrainsMonoFont}" FontSize="13" VerticalAlignment="Center"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Stok Gd" Width="1.0*" CanUserSort="False">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding StockWarehouse}" Foreground="{Binding StockWarehouse, Converter={StaticResource StockColorConverter}}" FontFamily="{DynamicResource JetBrainsMonoFont}" FontSize="13" VerticalAlignment="Center"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Status"      Binding="{Binding Status}"       Width="0.7*" CanUserSort="False"/>
        </DataGrid.Columns>
      </DataGrid>
      <TabControl Grid.Row="1" x:Name="TabDetail" Background="{DynamicResource Bg0Brush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}" FontSize="12">
        <TabItem Header="Umum" Foreground="{DynamicResource FgPrimaryBrush}">
          <ScrollViewer>
            <StackPanel Margin="12,8" Spacing="6">
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Kode Barang:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtCode" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Nama:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtName" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Barcode:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtBarcode" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Satuan:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtUnit" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Departemen:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="CboDept" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" HorizontalAlignment="Stretch"/>
              </Grid>
              <Grid ColumnDefinitions="160,*">
                <TextBlock Grid.Column="0" Text="Status:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="CboStatus" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Width="150">
                  <ComboBoxItem Content="A - Active"/>
                  <ComboBoxItem Content="I - Inactive"/>
                </ComboBox>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
        <TabItem Header="Harga" Foreground="{DynamicResource FgPrimaryBrush}">
          <ScrollViewer>
            <StackPanel Margin="12,8" Spacing="6">
              <Grid ColumnDefinitions="160,200,120,80">
                <TextBlock Grid.Column="0" Text="Harga Jual:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtPrice" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200,120,80">
                <TextBlock Grid.Column="0" Text="Harga 1 (Grosir):" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtPrice1" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200,120,80">
                <TextBlock Grid.Column="0" Text="Harga 2:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtPrice2" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
                <TextBlock Grid.Column="2" Text="Batas Qty 2:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBox Grid.Column="3" x:Name="TxtQtyBreak2" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200,120,80">
                <TextBlock Grid.Column="0" Text="Harga 3:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtPrice3" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
                <TextBlock Grid.Column="2" Text="Batas Qty 3:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBox Grid.Column="3" x:Name="TxtQtyBreak3" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200">
                <TextBlock Grid.Column="0" Text="Harga 4:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtPrice4" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200">
                <TextBlock Grid.Column="0" Text="Harga Beli:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtBuyingPrice" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,200">
                <TextBlock Grid.Column="0" Text="Harga Pokok:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="TxtCostPrice" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
              </Grid>
              <Grid ColumnDefinitions="160,150">
                <TextBlock Grid.Column="0" Text="Open Price:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="CboOpenPrice" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13">
                  <ComboBoxItem Content="N"/><ComboBoxItem Content="Y"/>
                </ComboBox>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
        <TabItem Header="Lain-lain" Foreground="{DynamicResource FgPrimaryBrush}">
          <StackPanel Margin="12,8" Spacing="6">
            <Grid ColumnDefinitions="160,200">
              <TextBlock Grid.Column="0" Text="Disc %:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBox Grid.Column="1" x:Name="TxtDiscPct" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
            </Grid>
            <Grid ColumnDefinitions="160,200">
              <TextBlock Grid.Column="0" Text="Kode Vendor:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
              <TextBox Grid.Column="1" x:Name="TxtVendorCode" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13" Height="28"/>
            </Grid>
            <Grid ColumnDefinitions="160,150">
              <TextBlock Grid.Column="0" Text="PPN:" Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Center"/>
              <ComboBox x:Name="CboVatFlag" Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" FontSize="13">
                <ComboBoxItem Content="N"/><ComboBoxItem Content="Y"/>
              </ComboBox>
            </Grid>
          </StackPanel>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</UserControl>
