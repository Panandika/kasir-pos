<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Master.DepartmentView"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <DataGrid x:Name="DgvDepts"
              x:CompileBindings="False"
              AutoGenerateColumns="False"
              SelectionMode="Single"
              Foreground="#00dc00"
              Background="#001400"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode" Binding="{Binding DeptCode}"
                            Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Nama" Binding="{Binding Name}"
                            Width="4*" CanUserSort="False" />
        <DataGridTextColumn Header="Diubah" Binding="{Binding ChangedAt}"
                            Width="2*" CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
