<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Shared.MsgBoxWindow"
        Width="480" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#000000"
        WindowDecorations="None">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Center" Spacing="12" Margin="0,12,0,0">
      <Button x:Name="BtnYes" Content="Ya / OK"
              Width="100" Height="34"
              Background="#004400" Foreground="#00dc00"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13" />
      <Button x:Name="BtnNo" Content="Tidak / Batal"
              Width="100" Height="34"
              Background="#440000" Foreground="#ff5050"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              IsVisible="False" />
    </StackPanel>
    <TextBlock x:Name="MsgText"
               TextWrapping="Wrap"
               FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
               FontSize="13"
               Foreground="#00dc00"
               VerticalAlignment="Center"
               HorizontalAlignment="Center" />
  </DockPanel>
</Window>
