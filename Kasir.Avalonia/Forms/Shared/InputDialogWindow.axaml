<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Shared.InputDialogWindow"
        Width="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource Bg0Brush}"
        WindowDecorations="None">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button x:Name="BtnOk" Content="OK"
              Width="90" Height="32"
              Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13" />
      <Button x:Name="BtnCancel" Content="Batal"
              Width="90" Height="32"
              Background="{DynamicResource AccentBgBrush}" Foreground="{DynamicResource DangerBrush}"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13" />
    </StackPanel>
    <StackPanel x:Name="FieldPanel" Spacing="6" />
  </DockPanel>
</Window>
