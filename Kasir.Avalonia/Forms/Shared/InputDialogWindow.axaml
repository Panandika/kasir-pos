<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Shared.InputDialogWindow"
        Width="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#000000"
        WindowDecorations="None">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button x:Name="BtnOk" Content="OK"
              Width="90" Height="32"
              Background="#004400" Foreground="#00dc00"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13" />
      <Button x:Name="BtnCancel" Content="Batal"
              Width="90" Height="32"
              Background="#440000" Foreground="#ff5050"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13" />
    </StackPanel>
    <StackPanel x:Name="FieldPanel" Spacing="6" />
  </DockPanel>
</Window>
