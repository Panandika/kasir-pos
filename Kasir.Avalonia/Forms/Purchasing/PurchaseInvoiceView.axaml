<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Purchasing.PurchaseInvoiceView"
             Background="#000000">
  <DockPanel>
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Border>

    <!-- Footer total -->
    <Border DockPanel.Dock="Bottom" Background="#001400" Height="38"
            BorderBrush="#00a000" BorderThickness="0,1,0,0">
      <TextBlock x:Name="LblTotal"
                 Text="TOTAL: Rp 0"
                 Foreground="#00ff00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="14"
                 FontWeight="Bold"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,20,0" />
    </Border>

    <!-- Header: two rows -->
    <Border DockPanel.Dock="Top" Background="#001400" Height="60"
            BorderBrush="#00a000" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,250,Auto,120,Auto,50,Auto,140" RowDefinitions="Auto,Auto" Margin="10,4">
        <!-- Row 0: Supplier -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Supplier:"
                   Foreground="#006400" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="7" x:Name="TxtVendor"
                 IsReadOnly="True"
                 Background="#001400" Foreground="#00dc00" CaretBrush="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" Height="26" Margin="0,2,0,2" />

        <!-- Row 1: Tgl Faktur + Terms + Jatuh Tempo -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tgl Faktur:"
                   Foreground="#006400" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtDate"
                 Background="#001400" Foreground="#00dc00" CaretBrush="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" Height="26" Margin="0,2,16,2" />
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Terms:"
                   Foreground="#006400" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="3" x:Name="TxtTerms"
                 Text="30"
                 Background="#001400" Foreground="#00dc00" CaretBrush="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" Height="26" Margin="0,2,16,2" />
        <TextBlock Grid.Row="1" Grid.Column="4" Text="Jatuh Tempo:"
                   Foreground="#006400" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="5" Grid.ColumnSpan="3" x:Name="TxtDueDate"
                 Background="#001400" Foreground="#00dc00" CaretBrush="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" Height="26" Margin="0,2,0,2" />
      </Grid>
    </Border>

    <!-- Items grid -->
    <DataGrid x:Name="DgvItems"
              AutoGenerateColumns="False"
              SelectionMode="Single"
              Foreground="#00dc00"
              Background="#001400"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              IsReadOnly="True"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="No"     Binding="{Binding No}"    Width="0.4*" CanUserSort="False" />
        <DataGridTextColumn Header="Kode"   Binding="{Binding Code}"  Width="1.4*" CanUserSort="False" />
        <DataGridTextColumn Header="Nama"   Binding="{Binding Name}"  Width="2.5*" CanUserSort="False" />
        <DataGridTextColumn Header="Qty"    Binding="{Binding Qty}"   Width="0.8*" CanUserSort="False" />
        <DataGridTextColumn Header="Harga"  Binding="{Binding Price}" Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Jumlah" Binding="{Binding Total}" Width="1.2*" CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
