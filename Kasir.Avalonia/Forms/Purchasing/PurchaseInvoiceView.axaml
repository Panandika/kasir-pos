<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Purchasing.PurchaseInvoiceView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Border>

    <!-- Footer totals: 4-line breakdown -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg1Brush}" Height="82"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
      <Grid Margin="0,0,20,0">
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock x:Name="LblGross"
                     Text="TOTAL BELI: Rp 0"
                     Foreground="{DynamicResource FgPrimaryBrush}"
                     FontFamily="{DynamicResource JetBrainsMonoFont}"
                     FontSize="13"
                     HorizontalAlignment="Right" />
          <TextBlock x:Name="LblDisc"
                     Text="TOTAL DISC: Rp 0"
                     Foreground="{DynamicResource FgPrimaryBrush}"
                     FontFamily="{DynamicResource JetBrainsMonoFont}"
                     FontSize="13"
                     HorizontalAlignment="Right" />
          <TextBlock x:Name="LblVat"
                     Text="TOTAL PPN: Rp 0"
                     Foreground="{DynamicResource FgPrimaryBrush}"
                     FontFamily="{DynamicResource JetBrainsMonoFont}"
                     FontSize="13"
                     HorizontalAlignment="Right" />
          <TextBlock x:Name="LblNetto"
                     Text="TOTAL NETTO: Rp 0"
                     Foreground="{DynamicResource FgPrimaryBrush}"
                     FontFamily="{DynamicResource JetBrainsMonoFont}"
                     FontSize="13"
                     FontWeight="Bold"
                     HorizontalAlignment="Right" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Header: four rows (auto-sized to content) -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg1Brush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,140,Auto,140,Auto,140,Auto,140" RowDefinitions="Auto,Auto,Auto,Auto" Margin="10,4">
        <!-- Row 0: Faktur + BPB + No.PO + Tgl.PO -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Faktur:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTaxInvoice"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="0" Grid.Column="2" Text="BPB:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtDeliveryNote"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="0" Grid.Column="4" Text="No.PO:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="0" Grid.Column="5" x:Name="TxtRefNo"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="0" Grid.Column="6" Text="Tgl.PO:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="0" Grid.Column="7" x:Name="TxtTaxInvDate"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,0,2" />

        <!-- Row 1: Supplier + Lokasi + Disc -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Supplier:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtVendor"
                 IsReadOnly="True"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="1" Grid.Column="4" Text="Lokasi:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="5" x:Name="TxtWarehouse"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="1" Grid.Column="6" Text="Disc%:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="1" Grid.Column="7" x:Name="TxtDiscPct"
                 Text="0"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,0,2" />

        <!-- Row 2: Tgl.Faktur + Tgl.Terima + Terms + Jatuh Tempo -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tgl.Faktur:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtDate"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="2" Grid.Column="2" Text="Tgl.Terima:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="2" Grid.Column="3" x:Name="TxtReceivedDate"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="2" Grid.Column="4" Text="Terms:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="2" Grid.Column="5" x:Name="TxtTerms"
                 Text="30"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
        <TextBlock Grid.Row="2" Grid.Column="6" Text="Jatuh Tempo:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="2" Grid.Column="7" x:Name="TxtDueDate"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,0,2" />

        <!-- Row 3: PPM% -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="PPM%:"
                   Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtVatFlag"
                 Text="N"
                 Background="{DynamicResource Bg1Brush}" Foreground="{DynamicResource FgPrimaryBrush}" CaretBrush="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" Height="26" Margin="0,2,8,2" />
      </Grid>
    </Border>

    <!-- Items grid -->
    <DataGrid x:Name="DgvItems"
              AutoGenerateColumns="False"
              SelectionMode="Single"
              Foreground="{DynamicResource FgPrimaryBrush}"
              Background="{DynamicResource Bg1Brush}"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              IsReadOnly="True"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="No"     Binding="{Binding No}"    Width="0.4*" CanUserSort="False" />
        <DataGridTextColumn Header="Kode"   Binding="{Binding Code}"  Width="1.4*" CanUserSort="False" />
        <DataGridTextColumn Header="Nama"   Binding="{Binding Name}"  Width="2.5*" CanUserSort="False" />
        <DataGridTextColumn Header="Qty"    Binding="{Binding Qty}"   Width="0.8*" CanUserSort="False" />
        <DataGridTextColumn Header="Unit"   Binding="{Binding Unit}"  Width="0.6*" CanUserSort="False" />
        <DataGridTextColumn Header="Harga"  Binding="{Binding Price}" Width="1.2*" CanUserSort="False" />
        <DataGridTextColumn Header="Jumlah" Binding="{Binding Total}" Width="1.2*" CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
