<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Accounting.AccountsWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Border DockPanel.Dock="Top" Background="#002800" Height="38" Padding="8,4">
      <Grid ColumnDefinitions="Auto,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Text="Search:"
                   Foreground="#00dc00"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
        <TextBox Grid.Column="1"
                 x:Name="TxtSearch"
                 Width="320"
                 Height="28"
                 Background="#001400"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="13" />
        <Button Grid.Column="2"
                x:Name="BtnSearch"
                Content="F2"
                Width="50"
                Height="28"
                Margin="6,0,0,0"
                Background="#004400"
                Foreground="#00dc00"
                FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                FontSize="13" />
      </Grid>
    </Border>
    <DataGrid x:Name="DgvAccounts"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="#000000"
              Foreground="#00dc00"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13"
              GridLinesVisibility="Horizontal"
              HorizontalScrollBarVisibility="Disabled"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"       Binding="{Binding Code}"      Width="1.2*" />
        <DataGridTextColumn Header="Nama"       Binding="{Binding Name}"      Width="3*"   />
        <DataGridTextColumn Header="Grup"       Binding="{Binding Group}"     Width="1*"   />
        <DataGridTextColumn Header="Saldo Nor." Binding="{Binding NormalBal}" Width="0.6*" />
        <DataGridTextColumn Header="Detail"     Binding="{Binding Detail}"    Width="0.6*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
