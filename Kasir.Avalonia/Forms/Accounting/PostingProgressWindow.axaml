<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Accounting.PostingProgressWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <TextBox x:Name="TxtLog"
             Background="#001400"
             Foreground="#00dc00"
             FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
             FontSize="13"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="NoWrap" />
  </DockPanel>
</Window>
