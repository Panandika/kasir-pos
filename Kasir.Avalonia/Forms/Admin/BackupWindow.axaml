<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Admin.BackupWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="#002800" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel>
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16"
                  Width="500">
        <TextBlock Text="BACKUP DATABASE"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#00dc00"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace" />
        <TextBlock Text="Menyalin kasir.db ke folder tujuan dengan timestamp.&#10;Disarankan: backup ke USB setiap hari."
                   Foreground="#008800"
                   FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                   FontSize="13"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />
        <Button x:Name="BtnBackup"
                Content="Backup Sekarang"
                Width="250" Height="44"
                Background="#004400" Foreground="#00dc00"
                FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                FontSize="13"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Panel>
  </DockPanel>
</Window>
