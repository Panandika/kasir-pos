<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Admin.UserView"
             x:DataType="x:Object"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <DataGrid x:Name="DgvUsers"
              AutoGenerateColumns="False"
              SelectionMode="Single"
              Foreground="{DynamicResource FgPrimaryBrush}"
              Background="{DynamicResource Bg1Brush}"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13"
              CanUserReorderColumns="False"
              CanUserResizeColumns="True"
              IsReadOnly="True"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="2*" CanUserSort="False" />
        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="3*" CanUserSort="False" />
        <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="1*" CanUserSort="False" />
        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1.5*" CanUserSort="False" />
        <DataGridTextColumn Header="Aktif" Binding="{Binding Active}" Width="1*" CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
