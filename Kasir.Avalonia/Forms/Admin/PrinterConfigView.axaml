<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Admin.PrinterConfigView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel>
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16"
                  Width="500">
        <TextBlock Text="KONFIGURASI PRINTER"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="{DynamicResource JetBrainsMonoFont}" />
        <TextBlock Text="Nama Printer (dari Devices and Printers):"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <TextBox x:Name="TxtPrinterName"
                 Width="460"
                 Height="34"
                 Background="{DynamicResource Bg1Brush}"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="13" />
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
          <Button x:Name="BtnTestPrint"
                  Content="Test Print"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
          <Button x:Name="BtnTestDrawer"
                  Content="Test Drawer"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
          <Button x:Name="BtnSave"
                  Content="Simpan"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
        </StackPanel>
      </StackPanel>
    </Panel>
  </DockPanel>
</UserControl>
