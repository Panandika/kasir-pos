<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Admin.PrinterConfigView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel>
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="14"
                  Width="540">
        <TextBlock Text="KONFIGURASI PRINTER"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="{DynamicResource JetBrainsMonoFont}" />

        <TextBlock Text="Tipe Koneksi:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <ComboBox x:Name="CmbKind"
                  Width="500" Height="34"
                  Background="{DynamicResource Bg1Brush}"
                  Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />

        <TextBlock Text="Printer / Port:"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13" />
        <Grid ColumnDefinitions="*,Auto" Width="500">
          <ComboBox x:Name="CmbName"
                    Grid.Column="0"
                    Height="34"
                    IsEditable="True"
                    Background="{DynamicResource Bg1Brush}"
                    Foreground="{DynamicResource FgPrimaryBrush}"
                    FontFamily="{DynamicResource JetBrainsMonoFont}"
                    FontSize="13" />
          <Button x:Name="BtnRefresh"
                  Grid.Column="1"
                  Content="↻"
                  Width="40" Height="34"
                  Margin="6,0,0,0"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="14"
                  ToolTip.Tip="Refresh daftar" />
        </Grid>

        <StackPanel x:Name="BaudRow" Orientation="Vertical" Spacing="6" IsVisible="False">
          <TextBlock Text="Baud Rate (serial):"
                     Foreground="{DynamicResource FgPrimaryBrush}"
                     FontFamily="{DynamicResource JetBrainsMonoFont}"
                     FontSize="13" />
          <ComboBox x:Name="CmbBaud"
                    Width="500" Height="34"
                    Background="{DynamicResource Bg1Brush}"
                    Foreground="{DynamicResource FgPrimaryBrush}"
                    FontFamily="{DynamicResource JetBrainsMonoFont}"
                    FontSize="13" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,8,0,0">
          <Button x:Name="BtnTestPrint"
                  Content="Test Print"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
          <Button x:Name="BtnTestDrawer"
                  Content="Test Drawer"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
          <Button x:Name="BtnSave"
                  Content="Simpan"
                  Width="150" Height="34"
                  Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                  FontFamily="{DynamicResource JetBrainsMonoFont}"
                  FontSize="13" />
        </StackPanel>
      </StackPanel>
    </Panel>
  </DockPanel>
</UserControl>
