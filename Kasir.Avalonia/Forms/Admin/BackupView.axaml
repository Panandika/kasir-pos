<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Admin.BackupView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Panel DockPanel.Dock="Bottom" Background="{DynamicResource Bg2Brush}" Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Panel>
    <Panel>
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16"
                  Width="500">
        <TextBlock Text="BACKUP DATABASE"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource FgPrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="{DynamicResource JetBrainsMonoFont}" />
        <TextBlock Text="Menyalin kasir.db ke folder tujuan dengan timestamp.&#10;Disarankan: backup ke USB setiap hari."
                   Foreground="{DynamicResource FgSecondaryBrush}"
                   FontFamily="{DynamicResource JetBrainsMonoFont}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />
        <Button x:Name="BtnBackup"
                Content="Backup Sekarang"
                Width="250" Height="44"
                Background="{DynamicResource BgSelectedBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                FontFamily="{DynamicResource JetBrainsMonoFont}"
                FontSize="13"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Panel>
  </DockPanel>
</UserControl>
