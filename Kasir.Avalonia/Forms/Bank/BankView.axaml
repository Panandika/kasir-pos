<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kasir.Avalonia.Forms.Bank.BankView"
             Background="{DynamicResource Bg0Brush}">
  <DockPanel>
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource Bg2Brush}"
            Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="{DynamicResource FgPrimaryBrush}"
                 FontFamily="{DynamicResource JetBrainsMonoFont}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Border>
    <DataGrid x:Name="DgvBanks"
              AutoGenerateColumns="False"
              Background="{DynamicResource Bg1Brush}"
              Foreground="{DynamicResource FgPrimaryBrush}"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              IsReadOnly="True"
              FontFamily="{DynamicResource JetBrainsMonoFont}"
              FontSize="13"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"
                            Binding="{Binding Code}"
                            Width="*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Nama"
                            Binding="{Binding Name}"
                            Width="2*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="No. Rekening"
                            Binding="{Binding AccNo}"
                            Width="1.8*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Cabang"
                            Binding="{Binding Branch}"
                            Width="1.5*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Pemegang"
                            Binding="{Binding Holder}"
                            Width="1.8*"
                            CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
