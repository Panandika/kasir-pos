<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Kasir.Avalonia.Forms.Bank.BankWindow"
        WindowState="FullScreen"
        WindowDecorations="None"
        Background="#000000">
  <DockPanel>
    <Border DockPanel.Dock="Bottom"
            Background="#002800"
            Height="28">
      <TextBlock x:Name="StatusLabel"
                 Foreground="#00dc00"
                 FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
                 FontSize="12"
                 VerticalAlignment="Center"
                 Margin="8,0" />
    </Border>
    <DataGrid x:Name="DgvBanks"
              AutoGenerateColumns="False"
              Background="#001400"
              Foreground="#00dc00"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              IsReadOnly="True"
              FontFamily="Consolas,Cascadia Mono,Liberation Mono,DejaVu Sans Mono,monospace"
              FontSize="13">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kode"
                            Binding="{Binding Code}"
                            Width="*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Nama"
                            Binding="{Binding Name}"
                            Width="2*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="No. Rekening"
                            Binding="{Binding AccNo}"
                            Width="1.8*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Cabang"
                            Binding="{Binding Branch}"
                            Width="1.5*"
                            CanUserSort="False" />
        <DataGridTextColumn Header="Pemegang"
                            Binding="{Binding Holder}"
                            Width="1.8*"
                            CanUserSort="False" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
